{
    "name": "mainlayer/mainlayer-php",
    "description": "Official PHP SDK for Mainlayer — payment infrastructure for AI agents",
    "type": "library",
    "license": "MIT",
    "keywords": ["mainlayer", "payments", "ai", "agents", "sdk"],
    "homepage": "https://mainlayer.xyz",
    "authors": [
        {
            "name": "Mainlayer",
            "email": "support@mainlayer.xyz",
            "homepage": "https://mainlayer.xyz"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mainlayer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mainlayer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=5",
        "lint": "phpstan analyse src --level=5"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
